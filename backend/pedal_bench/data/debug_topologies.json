  "audio_probe_procedure": [
    "Power the pedal (9V DC, correct polarity). Confirm LED on and current draw <50 mA.",
    "Engage bypass (footswitch). With no signal applied, gently tap the input jack tip with a finger — you should hear hum/buzz at the output. If silent, the bypass path is broken (check switch wiring and jack tip connections).",
    "Apply a signal source (guitar or audio player). With bypass engaged, confirm clean signal passes through to the amp.",
    "Engage the effect. If silent, suspect the effect signal path.",
    "Build an audio probe: 100 nF cap in series with a 10\u201350 k\u03a9 resistor, probe tip on one end, alligator clip to an amp input on the other, ground clip to pedal ground.",
    "Trace the signal by touching the probe to each op-amp output pin in circuit order. The first pin where audio disappears marks the dead stage.",
    "At the dead stage: check the op-amp's supply pins (V+ \u2248 9 V, V- \u2248 0 V), then the non-inverting input (should be at VREF \u2248 4.5 V). Swap the IC if voltages look right but no output."
  ],

  "common_failures": [
    { "symptom": "No LED, no sound at all", "likely_causes": ["DC jack wiring backwards (sleeve vs tip on a switching jack)", "Wrong polarity power supply", "Solder bridge on DC input"] },
    { "symptom": "LED on, no sound bypassed OR engaged", "likely_causes": ["Input or output jack wired to tip/ring/sleeve incorrectly", "Cold solder joint on a jack lug", "Missing ground wire to the jack"] },
    { "symptom": "Bypass works, effect is silent", "likely_causes": ["IC orientation reversed (check notch)", "VREF not at ~4.5 V (bad bias resistor or electrolytic)", "Wrong value cap in signal path", "Broken footswitch wiring"] },
    { "symptom": "Effect works but very quiet", "likely_causes": ["Solder bridge shorting signal to ground", "Feedback resistor wrong value", "Pot wired backwards"] },
    { "symptom": "Weird oscillation or squealing", "likely_causes": ["Socketed IC making poor contact", "Missing bypass cap near IC supply pin", "Ground loop in wiring layout", "High-gain op-amp with insufficient decoupling"] },
    { "symptom": "LED dim or flickering", "likely_causes": ["Wrong CLR resistor value (too high)", "Reversed LED", "Failing footswitch contact"] }
  ]
}
