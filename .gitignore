.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Frontend
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# Root workspace lockfile only (no node_modules committed)
# (node_modules/ already ignored above)

# Build artifacts
backend/build/
backend/*.egg-info/

# User build data — each user owns their projects/ folder
projects/*
!projects/.gitkeep

# User inventory is personal
inventory.json

# Personal scratch notes (not for the repo)
projectnotes.txt

# Secrets — API keys, etc. Never commit.
.env
.env.*
!.env.example
*.env.txt

# User data stays in-repo (small JSON) — do not ignore `projects/` or
# `inventory.json`. Do ignore generated STLs if you prefer to regenerate:
# projects/*/drill/*.stl

# SQLite index (rebuilt from projects/ JSON on demand)
pedal_bench_index.sqlite
